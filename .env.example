# Required in production for Vercel Cron route protection.
CRON_SECRET="replace-with-a-long-random-token"

# Preferred on Vercel: add the Neon Marketplace integration. The app reads
# POSTGRES_URL first, then DATABASE_URL, then the Supabase variables below.
POSTGRES_URL="postgresql://..."
DATABASE_URL=""

# Optional. When present, API and cron routes upsert/read signal cards through
# Supabase PostgREST with a service role key. Without these, the app runs in
# deterministic demo mode.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional free data/API keys. The Python ETL runs without them and uses Stooq
# plus deterministic fallback samples where remote sources are unavailable.
ALPHA_VANTAGE_API_KEY=""
FRED_API_KEY=""
EIA_API_KEY=""

# Optional future model integration. MVP ships with deterministic RAG synthesis
# and evaluation harness so the workflow is testable without LLM spend.
AI_PROVIDER="deterministic"
OPENAI_API_KEY=""
LLM_MODEL="gpt-4.1-mini"
MAX_AI_THEMES="20"
